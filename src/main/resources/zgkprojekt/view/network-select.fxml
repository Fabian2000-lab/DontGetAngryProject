<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="1080.0" prefWidth="1920.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="zgkprojekt.controller.NetworkSelectController">
 <top>
	<Label text="Select mode" BorderPane.alignment="CENTER">
	   <font>
		  <Font name="MS Outlook" size="59.0" />
	   </font>
	</Label>
 </top>
 <center>
	<VBox alignment="CENTER" prefHeight="485.0" prefWidth="1920.0" spacing="40.0" BorderPane.alignment="CENTER">
	   <children>
		  <Button mnemonicParsing="false" onAction="#handleStartLocalGame" prefHeight="75.0" prefWidth="400.0" style="-fx-background-radius: 20;" text="Local Game" textAlignment="CENTER">
			 <font>
				<Font name="Constantia" size="38.0" />
			 </font>
		  </Button>
		  <Button mnemonicParsing="false" prefHeight="75.0" prefWidth="416.0" style="-fx-background-radius: 20;" text="Network Game" textAlignment="CENTER">
			 <font>
				<Font name="Constantia" size="38.0" />
			 </font>
		  </Button>
	   </children>
	</VBox>
 </center>
</BorderPane>
